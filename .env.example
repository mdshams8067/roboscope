# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "gemini" (default, free tier available) or "anthropic"
LLM_PROVIDER=gemini

# ── Google Gemini — required when LLM_PROVIDER=gemini ────────────────────────
# Get yours at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override the default model names
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGEN_MODEL=imagen-3.0-fast-generate-001

# ── Anthropic — required when LLM_PROVIDER=anthropic ─────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: override the default model
# ANTHROPIC_TEXT_MODEL=claude-sonnet-4-5

# ── Graphical abstracts (optional) ───────────────────────────────────────────
# Generates AI images for articles that have no og:image.
# Requires Gemini billing enabled — Imagen is a paid API.
# Only works when LLM_PROVIDER=gemini.
USE_GRAPHICAL_ABSTRACT=false

# ── OpenReview (required for CoRL, RSS, ICLR, NeurIPS, ICML) ────────────────
# Create a free account at https://openreview.net/
OPENREVIEW_USERNAME=your_openreview_email_here
OPENREVIEW_PASSWORD=your_openreview_password_here

# ── Supabase (image storage for graphical abstracts) ─────────────────────────
# Required only if USE_GRAPHICAL_ABSTRACT=true
# Get yours at https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
